{
  "expo": {
    "name": "AiForge",
    "slug": "forge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiforge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.emergent.fierceforgeios2c75fc60",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Pick photos and videos to edit with AI",
        "NSPhotoLibraryAddUsageDescription": "Save edited creations back to your library",
        "NSCameraUsageDescription": "Capture photos and videos to edit with AI"
      }
    },
    "android": {
      "package": "app.emergent.fierceforgeios2c75fc60",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#020208"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET",
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick photos and videos to edit with AI",
          "cameraPermission": "Capture photos and videos to edit with AI"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#020208"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f5b6e26b-8b5e-4c7a-9a0e-7c5d4b3a2e1f"
      },
      "fingerprints": {
        "sha256_verified": "0C:A8:A8:11:B3:A0:58:28:05:17:D9:1C:43:A5:62:63:C4:45:05:34:26:BF:19:D1:1F:FB:0E:4A:4B:1E:01:84",
        "sha256_in_review": "98:7A:C1:49:B7:9C:03:FC:82:41:B7:94:FA:97:9D:45:CC:2D:46:D5:1F:B1:50:7F:F4:98:0A:5F:9A:D9:2B:14",
        "sha1": "B4:DB:18:ED:77:47:A9:E7:62:97:27:88:4C:55:E8:CD:DE:19:80:68"
      }
    }
  }
}
